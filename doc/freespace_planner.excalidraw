    {
      "id": "8KC_KyXMEfawspDl5krvW",
      "type": "text",
      "x": 1692.6035133125401,
      "y": 5625.110061975287,
      "width": 645.9373779296875,
      "height": 367.20000000000005,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
