    {
      "id": "w5MeipFQXbiOHQiN_uKtc",
      "type": "text",
      "x": 3375.9049687331208,
      "y": 1958.1344431606087,
      "width": 403.0248107910156,
      "height": 100,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b05x",
      "roundness": null,
      "seed": 1085534295,
      "version": 1137,
      "versionNonce": 1248287193,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781156804330,
      "link": null,
      "locked": false,
      "text": "If we are serious about functional decomposition\ninto different nodes, we should NOT handle setting\nof auto state, multiplexer etc. in the planner.\nThe planner should only output trajectories, handle\ntheir replanning etc. ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If we are serious about functional decomposition\ninto different nodes, we should NOT handle setting\nof auto state, multiplexer etc. in the planner.\nThe planner should only output trajectories, handle\ntheir replanning etc. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
