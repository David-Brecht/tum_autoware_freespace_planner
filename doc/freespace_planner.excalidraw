      "updated": 1780279496775,
      "link": null,
      "locked": false,
      "text": "Step 0: Look at the library for freespace planning\nStep 1: Decide: Do we want to build upon the existing freespace planner?\nStep 2: Make the goal point along the path (x m) → See if it works and is reactive enough\nStep 3: Tune it for different use cases\nStep 4: If successful: Implement the multi-planner approach → Likely needs a SM",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 0: Look at the library for freespace planning\nStep 1: Decide: Do we want to build upon the existing freespace planner?\nStep 2: Make the goal point along the path (x m) → See if it works and is reactive enough\nStep 3: Tune it for different use cases\nStep 4: If successful: Implement the multi-planner approach → Likely needs a SM",
      "autoResize": true,
      "lineHeight": 1.35
    },
