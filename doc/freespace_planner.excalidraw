    },
    {
      "id": "71EVT-cSw3kmhAQIb4FOE",
      "type": "text",
      "x": 3251.5192333361492,
      "y": 2718.918886063362,
      "width": 430.41705322265625,
      "height": 367.20000000000005,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0I",
      "roundness": null,
      "seed": 2029432185,
      "version": 904,
      "versionNonce": 116044601,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781157031203,
      "link": null,
      "locked": false,
      "text": "Only issue here:\nWhat happens if there are more\ntrajectories between receiving the message\non the operator side and setting the index\n\n→ One option here: Block generation of \ntrajectories via a new sub step after the \nOperator clicked \"Choose Trajectory\"\n\n→ Other option: Have a buffer of trajectories \nand match against the timestamp that the \noperators message has: If there is a newer \nCandidateTrajectory set on the planner side than the latest\nOperator input, then take the goal point (not the trajectory) \nat the respective timestamp  \n\n→ Keep track of goal poses and trajectories",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Only issue here:\nWhat happens if there are more\ntrajectories between receiving the message\non the operator side and setting the index\n\n→ One option here: Block generation of \ntrajectories via a new sub step after the \nOperator clicked \"Choose Trajectory\"\n\n→ Other option: Have a buffer of trajectories \nand match against the timestamp that the \noperators message has: If there is a newer \nCandidateTrajectory set on the planner side than the latest\nOperator input, then take the goal point (not the trajectory) \nat the respective timestamp  \n\n→ Keep track of goal poses and trajectories",
      "autoResize": true,
      "lineHeight": 1.35
    },
