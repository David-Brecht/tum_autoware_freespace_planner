<launch>
  <arg name="use_sim_time" default="false"/>

  <!-- DUMMY GUI -->
  <node pkg="tum_autoware_freespace_planner" exec="trajectory_selector_gui.py" name="trajectory_selector_gui" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <!-- FREESPACE PLANNER -->
  <arg name="input_path" default="/planning/scenario_planning/lane_driving/behavior_planning/path"/>
  <arg name="input_occupancy_grid" default="/planning/scenario_planning/parking/costmap_generator/occupancy_grid"/>
  <arg name="input_odometry" default="/localization/kinematic_state"/>
  <arg name="output_trajectory" default="/external/remote/trajectory"/>
  <arg name="output_path" default="/external/remote/path"/>
  <arg name="is_completed" default="is_completed"/>
  <arg name="param_file" default="$(find-pkg-share tum_autoware_freespace_planner)/config/freespace_planner.param.yaml"/>
  <arg name="vehicle_info_param_file" default="$(find-pkg-share sample_vehicle_description)/config/vehicle_info.param.yaml"/>
  
  <node pkg="tum_autoware_freespace_planner" exec="freespace_planner" namespace="/external/remote" name="freespace_planner" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <remap from="~/input/path" to="$(var input_path)"/>
    <remap from="~/input/occupancy_grid" to="$(var input_occupancy_grid)"/>
    <remap from="~/input/odometry" to="$(var input_odometry)"/>
    <remap from="~/output/trajectory" to="$(var output_trajectory)"/>
    <remap from="~/output/path" to="$(var output_path)"/>
    <remap from="is_completed" to="$(var is_completed)"/>
    <param from="$(var param_file)"/>
    <param from="$(var vehicle_info_param_file)"/>
  </node>
</launch>
